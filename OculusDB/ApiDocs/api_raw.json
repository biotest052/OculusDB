    {
      "url": "/api/v2/search?q=<term>&type=<type>&skip=<skip>&limit=<limit>&groups=<groups>&appid=<appid>&supportedInAppLanguages=<languages>&differenceNameTypes=<diffTypes>",
      "method": "GET",
      "description": "Executes a query on the db with the given term. Depending on the configuration required parameters may change",
      "parameters": [
        {
          "name": "term",
          "description": "The term to search for",
          "required": false
        },
        {
          "name": "type",
          "description": "The OculusDBType (see enums) of the objects you want to search for",
          "required": false
        },
        {
          "name": "skip",
          "description": "The amount of objects you want to skip",
          "required": false
        },
        {
          "name": "limit",
          "description": "The amount of objects you want to get",
          "required": false
        },
        {
          "name": "groups",
          "description": "The headset groups (see enum) you want to search for. Comma seperated",
          "required": false
        },
        {
          "name": "appid",
          "description": "The app id you want to search for. Relevant for things like versions",
          "required": false
        },
        {
          "name": "supportedInAppLanguages",
          "description": "The languages you want to filter for",
          "required": false
        },
        {
          "name": "differenceNameTypes",
          "description": "The Difference types (See enums) you want to search for",
          "required": false
        }
      ],
      "exampleUrl": "/api/v2/search?q=Beat Saber&type=Application",
      "exampleResponse": {}
    },
